FROM debian:bookworm-slim

# Add the official PostgreSQL apt repo so pg_dump version matches the server
RUN apt-get update && apt-get install -y gnupg curl \
    && curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc \
       | gpg --dearmor -o /usr/share/keyrings/pgdg.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/pgdg.gpg] https://apt.postgresql.org/pub/repos/apt bookworm-pgdg main" \
       > /etc/apt/sources.list.d/pgdg.list \
    && apt-get update \
    && apt-get install -y cron iputils-ping postgresql-client-17 \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Create the log file to be able to run tail
RUN touch /var/log/cron.log

# Copy backup script
COPY backup.sh /usr/local/bin/backup.sh
RUN chmod +x /usr/local/bin/backup.sh

# Setup cron jobs
RUN (crontab -l ; echo "*/5 * * * * curl -s http://deye_php/crontasks.php >> /var/log/cron.log") | crontab
RUN (crontab -l ; echo "0 2 * * * /usr/local/bin/backup.sh >> /var/log/cron.log 2>&1") | crontab

# Run the command on container startup
CMD printenv | grep '^PG' > /etc/backup-env && cron && tail -f /var/log/cron.log
